# =============================================================================
#  Vexigent Platform — Environment Variables
# =============================================================================


# LLM API Keys
# At least OPENAI_API_KEY is required. The others unlock their respective
# providers in the UI model selector.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...



# Pinecone 
# PINECONE_API_KEY  — your Pinecone project API key (required)
# PINECONE_ENV      — Pinecone cloud region  (default: us-east-1)
# PINECONE_CALL_INDEX — index used by the voice/Twilio server (default: call-support-index)

PINECONE_API_KEY=pcsk_...
PINECONE_ENV=us-east-1
PINECONE_CALL_INDEX=call-support-index


#AWS (only needed if you use the /s3/ ingestion endpoint) 
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# Twilio (voice/twilio_server.py)
# TWILIO_PHONE_NUMBER — your Twilio number in E.164 format, e.g. +12015551234
# PUBLIC_URL          — your ngrok / deployed HTTPS URL, no trailing slash
# ESCALATION_NUMBER   — E.164 number to forward calls when AI cannot help
# MAX_TURNS           — max conversation turns before auto-goodbye (default: 20)

TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
PUBLIC_URL=https://your-ngrok-subdomain.ngrok.io
ESCALATION_NUMBER=
MAX_TURNS=20


# Flask / Frontend (frontend/app.py) 
# API_URL    — where the FastAPI backend is running
# SECRET_KEY — Flask session secret; change this in production

API_URL=http://127.0.0.1:8000
SECRET_KEY=change-me-in-production


# SQLite (backend/main.py) 
# Path to the SQLite file that stores user accounts.
# Relative paths are resolved from the directory where you launch the backend.

USER_DB_PATH=users.db